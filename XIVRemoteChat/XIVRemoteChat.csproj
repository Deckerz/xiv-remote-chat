<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <InternalName>xiv-remote-chat</InternalName>
    <Name>XIV Remote Chat</Name>
    <Author>Chika</Author>
    <Description>Allows you to control any instance of FF connected to chat or send commands.</Description>
    <Punchline>Remote control of your chat.</Punchline>
    <Version>0.0.0.2</Version>
    <RepoUrl>https://github.com/Deckerz/xiv-remote-chat</RepoUrl>
    <Tags>chat;remote;commands</Tags>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  
  <Import Project="$(MSBuildProjectDirectory)\..\Directory.Build.user.props" Condition="Exists('$(MSBuildProjectDirectory)\..\Directory.Build.user.props')" />
</Project>
